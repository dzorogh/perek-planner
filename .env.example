# Supabase project settings → API
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Local-only: skip auth redirect to inspect the Soft Workshop shell.
# Never set this in Dokploy / production. Ignored when NODE_ENV=production.
# KEPLO_DEV_BYPASS_AUTH=true

# Optional: operator credentials for scripts/verify-rls-*.mjs authenticated RLS checks
# and Playwright planning-flow e2e (E2E_* aliases also accepted by e2e/planning-flow.spec.ts).
# SMOKE_OPERATOR_EMAIL=you@example.com
# SMOKE_OPERATOR_PASSWORD=your-password
# E2E_OPERATOR_EMAIL=you@example.com
# E2E_OPERATOR_PASSWORD=your-password

# --- OpenRouter — Next server only; NEVER NEXT_PUBLIC_* ---
# OPENROUTER_API_KEY=sk-or-...
# Optional model override (default: openai/gpt-4o-mini:nitro — invent/snacks)
# OPENROUTER_MODEL=openai/gpt-4o-mini:nitro
# Optional ranking headers for openrouter.ai
# OPENROUTER_HTTP_REFERER=http://localhost:3000
# OPENROUTER_APP_TITLE=Keplo
