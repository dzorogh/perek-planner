+/** Public suggestions API (Story 2.3 — AI generate buyable Menu). */
+
+export { buildCandidates } from "@/domain/suggestions/candidates";
+export {
+  LONG_IDLE_DAYS,
+  RATING_WEIGHT,
+  RECENT_MENUS_COOLDOWN,
+} from "@/domain/suggestions/constants";
+export {
+  SUGGESTION_FAIL_RU,
